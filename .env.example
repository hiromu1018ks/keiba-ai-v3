# Keiba AI v3 — DB 接続設定雛形（機密値プレースホルダ・実値はローカル .env のみ）
# 実パスワードは絶対に planning 文書や commit に書かない（anti-pattern #20 / ASVS V8）

# === raw 読取専用ロール（public.n_* と raw_everydb2 VIEW に対し SELECT-only） ===
KEIBA_DB_NAME=everydb2
KEIBA_DB_USER=<raw readonly role>
KEIBA_DB_PASSWORD=<your-password-here>
KEIBA_DB_HOST=localhost
KEIBA_DB_PORT=5432

# === スキーマ名（§12.2 5層） ===
KEIBA_DB_SCHEMA_RAW=public
KEIBA_DB_SCHEMA_NORMALIZED=normalized

# === normalized 書込ロール（REVIEWS HIGH #6・plan 01-03 の ETL が使用） ===
# normalized スキーマにのみ INSERT/UPDATE/DELETE を GRANT。raw(public.n_*) には SELECT-only。
KEIBA_ETL_DB_USER=<normalized write role>
KEIBA_ETL_DB_PASSWORD=<your-etl-password-here>

# === 管理者接続 DSN（Task 3 の CREATE ROLE / GRANT / REVOKE 実行用・D-06 二重保護必須化） ===
# superuser または everydb2 DB の所有者ロール。未設定時は scripts/run_apply_schema.py が即座に fail。
KEIBA_ADMIN_DSN=postgresql://admin:admin-password@localhost:5432/everydb2
